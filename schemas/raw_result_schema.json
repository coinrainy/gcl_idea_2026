{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pilot Raw Result Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "stage",
    "method",
    "objective_family",
    "dataset",
    "evaluation_setting",
    "graph_visibility",
    "split_type",
    "split_file",
    "split_seed",
    "model_seed",
    "config_path",
    "config_hash",
    "run_command",
    "commit_hash",
    "status",
    "failure_reason",
    "best_epoch",
    "valid_at_best",
    "test_at_best",
    "final_valid",
    "final_test",
    "evaluator_type",
    "evaluator_seed",
    "early_stopping_metric",
    "patience",
    "max_epochs",
    "pretrain_epochs",
    "backbone",
    "hidden_dim",
    "projection_dim",
    "budget_policy",
    "training_time_sec",
    "peak_memory_mb",
    "result_file_path",
    "log_path",
    "notes"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "stage": { "const": "pilot" },
    "method": { "type": "string" },
    "objective_family": { "type": "string" },
    "dataset": { "type": "string" },
    "evaluation_setting": { "enum": ["transductive", "inductive"] },
    "graph_visibility": { "type": "string" },
    "split_type": { "type": "string" },
    "split_file": { "type": "string" },
    "split_seed": { "type": "integer" },
    "model_seed": { "type": "integer" },
    "config_path": { "type": "string" },
    "config_hash": { "type": "string" },
    "run_command": { "type": "string" },
    "commit_hash": { "type": "string" },
    "status": { "enum": ["success", "fail"] },
    "failure_reason": { "type": ["string", "null"] },
    "best_epoch": { "type": ["integer", "null"] },
    "valid_at_best": { "type": ["number", "null"] },
    "test_at_best": { "type": ["number", "null"] },
    "final_valid": { "type": ["number", "null"] },
    "final_test": { "type": ["number", "null"] },
    "evaluator_type": { "type": "string" },
    "evaluator_seed": { "type": ["integer", "null"] },
    "early_stopping_metric": { "type": ["string", "null"] },
    "patience": { "type": ["integer", "null"] },
    "max_epochs": { "type": ["integer", "null"] },
    "pretrain_epochs": { "type": ["integer", "null"] },
    "backbone": { "type": "string" },
    "hidden_dim": { "type": ["integer", "null"] },
    "projection_dim": { "type": ["integer", "null"] },
    "budget_policy": { "type": "string" },
    "training_time_sec": { "type": ["number", "null"] },
    "peak_memory_mb": { "type": ["number", "null"] },
    "result_file_path": { "type": "string" },
    "log_path": { "type": "string" },
    "notes": { "type": "string" }
  }
}
